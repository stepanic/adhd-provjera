# Cloudflare Pages cache strategija za PWA.
# Vidi: https://developers.cloudflare.com/pages/configuration/headers/
#
# Cilj: agresivan immutable cache za hashed assete, ali fresh sw.js i
# index.html pri svakom otvaranju kako bi se update detektirao odmah.
# Bez ovoga Cloudflare default cache može odgoditi vidljivost novog deploy-a.

# Service worker — uvijek fresh.
# Bez ovoga browser može držati stari sw.js do 24h (SW-spec gornja granica)
# i nove verzije se ne registriraju.
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# Workbox runtime — isto fresh, jer ime nije hash-ovano.
/workbox-*.js
  Cache-Control: no-cache, no-store, must-revalidate

# Web manifest — može malo cache, ali ne pretjerano.
/manifest.webmanifest
  Cache-Control: public, max-age=3600

# Hashed asseti (Vite output) — content-addressable, sigurno immutable.
# Hash je u imenu file-a pa novi deploy = novi URL = novi cache entry.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# HTML — uvijek revalidirati (kratki ETag check).
# Ne smije se previše kesirati jer mijenja referencirane hash-ove.
/
  Cache-Control: public, max-age=0, must-revalidate

/index.html
  Cache-Control: public, max-age=0, must-revalidate

# Security headers (Cloudflare Pages default + naši nadoptaci).
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
